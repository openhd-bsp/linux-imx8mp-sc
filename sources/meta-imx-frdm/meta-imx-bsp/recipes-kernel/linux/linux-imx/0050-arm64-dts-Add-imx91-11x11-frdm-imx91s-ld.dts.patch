From 84ceeb8176c257c83b5ab8e9fde0939ad30f0de5 Mon Sep 17 00:00:00 2001
From: Yanan Yang <yanan.yang@nxp.com>
Date: Mon, 10 Mar 2025 11:55:23 +0900
Subject: [PATCH 08/10] arm64: dts: Add imx91-11x11-frdm-imx91s-ld.dts

Signed-off-by: Yanan Yang <yanan.yang@nxp.com>
---
 arch/arm64/boot/dts/freescale/Makefile        |  3 +-
 .../freescale/imx91-11x11-frdm-imx91s-ld.dts  | 37 +++++++++++++++++++
 2 files changed, 39 insertions(+), 1 deletion(-)
 create mode 100644 arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-ld.dts

diff --git a/arch/arm64/boot/dts/freescale/Makefile b/arch/arm64/boot/dts/freescale/Makefile
index 81dfa3ff29f5..ec6a19960207 100644
--- a/arch/arm64/boot/dts/freescale/Makefile
+++ b/arch/arm64/boot/dts/freescale/Makefile
@@ -415,7 +415,8 @@ dtb-$(CONFIG_ARCH_MXC) += imx91-11x11-evk.dtb \
 			  imx91-11x11-frdm-imx91s-8mic.dtb \
 			  imx91-11x11-frdm-imx91s-tianma-wvga-panel.dtb \
 			  imx91-11x11-frdm-imx91s-fec.dtb \
-			  imx91-11x11-frdm-imx91s-mt9m114.dtb
+			  imx91-11x11-frdm-imx91s-mt9m114.dtb \
+			  imx91-11x11-frdm-imx91s-ld.dtb
 
 imx93-11x11-evk-pmic-pf0900-dtbs := imx93-11x11-evk.dtb imx93-11x11-evk-pmic-pf0900.dtbo
 imx93-11x11-evk-pmic-pf0900-root-dtbs := imx93-11x11-evk-root.dtb imx93-11x11-evk-pmic-pf0900.dtbo
diff --git a/arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-ld.dts b/arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-ld.dts
new file mode 100644
index 000000000000..9f77b8095a92
--- /dev/null
+++ b/arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-ld.dts
@@ -0,0 +1,37 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright 2025 NXP
+ */
+
+#include "imx91-11x11-frdm-imx91s.dts"
+
+&flexspi1 {
+	assigned-clocks = <&clk IMX91_CLK_FLEXSPI1>;
+	assigned-clock-parents = <&clk IMX91_CLK_SYS_PLL_PFD1>;
+	assigned-clock-rates = <266000000>;
+};
+
+&lpm {
+	clocks = <&clk IMX91_CLK_DUMMY>, <&clk IMX91_CLK_WAKEUP_AXI>,
+		 <&clk IMX91_CLK_NIC_AXI>, <&clk IMX91_CLK_MEDIA_AXI>,
+		 <&clk IMX91_CLK_A55_PERIPH>, <&clk IMX91_CLK_A55_CORE>, <&clk IMX91_CLK_DUMMY>,
+		 <&clk IMX91_CLK_SYS_PLL_PFD0>, <&clk IMX91_CLK_SYS_PLL_PFD0_DIV2>,
+		 <&clk IMX91_CLK_SYS_PLL_PFD1>, <&clk IMX91_CLK_SYS_PLL_PFD1_DIV2>,
+		 <&clk IMX91_CLK_SYS_PLL_PFD2>, <&clk IMX91_CLK_SYS_PLL_PFD2_DIV2>;
+	no-od-mode;
+	ld-mode-enabled;
+	soc-supply = <&buck2>;
+	status = "okay";
+};
+
+&usdhc1 {
+	assigned-clocks = <&clk IMX91_CLK_USDHC1>;
+	assigned-clock-parents = <&clk IMX91_CLK_SYS_PLL_PFD1>;
+	assigned-clock-rates = <266000000>;
+};
+
+&usdhc2 {
+	assigned-clocks = <&clk IMX91_CLK_USDHC2>;
+	assigned-clock-parents = <&clk IMX91_CLK_SYS_PLL_PFD1>;
+	assigned-clock-rates = <266000000>;
+};
-- 
