From c7786795c1dc4b801f66e4291955d580cb708c5b Mon Sep 17 00:00:00 2001
From: Lei Xu <lei.xu@nxp.com>
Date: Tue, 11 Mar 2025 11:39:01 +0800
Subject: [PATCH 09/10] arm64: dts: Add imx91-11x11-frdm-imx91s-lpuart.dts

Signed-off-by: Lei Xu <lei.xu@nxp.com>
---
 arch/arm64/boot/dts/freescale/Makefile        |  4 +-
 .../imx91-11x11-frdm-imx91s-lpuart.dts        | 42 +++++++++++++++++++
 2 files changed, 45 insertions(+), 1 deletion(-)
 create mode 100644 arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-lpuart.dts

diff --git a/arch/arm64/boot/dts/freescale/Makefile b/arch/arm64/boot/dts/freescale/Makefile
index ec6a19960207..406b8ed8db9c 100644
--- a/arch/arm64/boot/dts/freescale/Makefile
+++ b/arch/arm64/boot/dts/freescale/Makefile
@@ -416,7 +416,9 @@ dtb-$(CONFIG_ARCH_MXC) += imx91-11x11-evk.dtb \
 			  imx91-11x11-frdm-imx91s-tianma-wvga-panel.dtb \
 			  imx91-11x11-frdm-imx91s-fec.dtb \
 			  imx91-11x11-frdm-imx91s-mt9m114.dtb \
-			  imx91-11x11-frdm-imx91s-ld.dtb
+			  imx91-11x11-frdm-imx91s-ld.dtb \
+			  imx91-11x11-frdm-imx91s-lpuart.dtb
+
 
 imx93-11x11-evk-pmic-pf0900-dtbs := imx93-11x11-evk.dtb imx93-11x11-evk-pmic-pf0900.dtbo
 imx93-11x11-evk-pmic-pf0900-root-dtbs := imx93-11x11-evk-root.dtb imx93-11x11-evk-pmic-pf0900.dtbo
diff --git a/arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-lpuart.dts b/arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-lpuart.dts
new file mode 100644
index 000000000000..2cebcc6e1292
--- /dev/null
+++ b/arch/arm64/boot/dts/freescale/imx91-11x11-frdm-imx91s-lpuart.dts
@@ -0,0 +1,42 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright 2025 NXP
+ */
+
+#include "imx91-11x11-frdm-imx91s.dts"
+
+/* Unbind lpuart5 from Bluetooth, use it for lpuart test. */
+&lpuart5 {
+	/delete-node/ bluetooth;
+};
+
+&lpuart6 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&pinctrl_uart6>;
+	status = "okay";
+};
+
+/*
+ * uart test port1. Note: don't use Bluetooth at the sametime.
+ * J12: Pin27--TX Pin28--RX Pin3--CTS Pin5--RTS
+ */
+&pinctrl_uart5 {
+	fsl,pins = <
+		MX91_PAD_GPIO_IO00__LPUART5_TX      0x31e
+		MX91_PAD_GPIO_IO01__LPUART5_RX      0x31e
+		MX91_PAD_GPIO_IO02__LPUART5_CTS_B   0x31e
+		MX91_PAD_GPIO_IO03__LPUART5_RTS_B   0x31e
+	>;
+};
+
+&iomuxc {
+/* uart test port2: J12: Pin7--TX Pin29--RX Pin31--CTS Pin26--RTS */
+	pinctrl_uart6: uart6grp {
+		fsl,pins = <
+			MX91_PAD_GPIO_IO04__LPUART6_TX		0x31e
+			MX91_PAD_GPIO_IO05__LPUART6_RX		0x31e
+			MX91_PAD_GPIO_IO06__LPUART6_CTS_B	0x31e
+			MX91_PAD_GPIO_IO07__LPUART6_RTS_B	0x31e
+		>;
+	};
+};
