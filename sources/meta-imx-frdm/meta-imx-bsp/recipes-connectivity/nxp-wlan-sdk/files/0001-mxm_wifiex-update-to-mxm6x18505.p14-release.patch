+		    handle->priv[i]->bss_started == MTRUE) {
+			PRINTM(MMSG, "stop iface, bss role:%d %s\n",
+			       GET_BSS_ROLE(handle->priv[i]),
+			       handle->priv[i]->netdev->name);
+			cfg80211_stop_iface(handle->priv[i]->wdev->wiphy,
+					    handle->priv[i]->wdev, GFP_KERNEL);
+		}
+	}
+
+	LEAVE();
+}
